SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=karaduttas@gmail.com
SMTP_PASS=your-app-password

# Mail From
MAIL_FROM="Assos Karadut Taş Otel <noreply@karaduttasotel.com>"

# Admin Auth
ADMIN_EMAIL=admin@karaduttasotel.com
ADMIN_PASSWORD_HASH=$2a$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SESSION_SECRET=your-very-long-random-secret-at-least-32-characters
